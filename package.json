{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --recursive --filter @work-planner/api --filter @work-planner/web dev",
    "build": "pnpm --recursive --sort build",
    "api:generate": "pnpm prepare:shared && pnpm --filter @work-planner/api openapi && pnpm --filter @work-planner/web api:generate",
    "api:check": "pnpm api:generate && git diff --exit-code apps/api/openapi.json apps/web/src/shared/api/generated/work-planner-api.ts",
    "db:generate": "pnpm --filter @work-planner/api db:generate",
    "db:migrate": "pnpm --filter @work-planner/api db:migrate",
    "db:setup": "pnpm --filter @work-planner/api auth:migrate && pnpm --filter @work-planner/api db:migrate",
    "prepare:shared": "pnpm --filter @work-planner/shared build",
    "test": "pnpm prepare:shared && pnpm --recursive --if-present test",
    "typecheck": "pnpm prepare:shared && pnpm --recursive --if-present typecheck",
    "lint": "eslint .",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
